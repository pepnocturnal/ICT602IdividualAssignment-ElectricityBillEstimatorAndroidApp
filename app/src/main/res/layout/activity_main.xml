<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#0097A7">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/imgProfile"
                    android:layout_width="149dp"
                    android:layout_height="127dp"
                    android:layout_marginBottom="12dp"
                    android:padding="8dp"
                    android:src="@drawable/logoelectric" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Electricity Bill Estimator"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calculate your monthly electricity cost"
                    android:textSize="13sp"
                    android:textColor="#B2EBF2"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Billing Details"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#0097A7"
                    android:paddingBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Billing Month"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#455A64"
                    android:paddingBottom="4dp"/>

                <Spinner
                    android:id="@+id/spinnerMonth"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_rounded"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Units Used (kWh)"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#455A64"
                    android:paddingBottom="4dp"/>

                <EditText
                    android:id="@+id/etUnit"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Enter value between 1 – 1000 kWh"
                    android:inputType="numberDecimal"
                    android:background="@drawable/bg_input_rounded"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textSize="14sp"
                    android:textColor="#263238"
                    android:textColorHint="#90A4AE"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Rebate Percentage"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#455A64"/>

                    <TextView
                        android:id="@+id/tvRebateLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rebate: 0%"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#0097A7"/>
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekBarRebate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="5"
                    android:progressTint="#0097A7"
                    android:thumbTint="#0097A7"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0%"
                        android:textSize="11sp"
                        android:textColor="#90A4AE"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5%"
                        android:textSize="11sp"
                        android:textColor="#90A4AE"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnCalculate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="CALCULATE BILL"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0097A7"
            android:stateListAnimator="@null"
            android:layout_marginBottom="16dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#E0F7FA"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Estimation Result"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#00838F"
                    android:paddingBottom="12dp"/>

                <TextView
                    android:id="@+id/tvTotalCharges"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total Charges: —"
                    android:textSize="15sp"
                    android:textColor="#37474F"
                    android:paddingBottom="8dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#B2EBF2"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvFinalCost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Final Cost after Rebate: —"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#00838F"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnViewRecords"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="VIEW ALL RECORDS"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#26A69A"
            android:stateListAnimator="@null"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnAbout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="ABOUT"
            android:textSize="14sp"
            android:textColor="#0097A7"
            android:backgroundTint="#E0F7FA"
            android:stateListAnimator="@null"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>