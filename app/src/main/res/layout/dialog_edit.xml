<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Billing Month"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#455A64"
        android:paddingBottom="6dp"/>

    <Spinner
        android:id="@+id/spinnerEditMonth"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_input_rounded"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="New Units Used (kWh)"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#455A64"
        android:paddingBottom="6dp"/>

    <EditText
        android:id="@+id/etEditUnit"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Enter value between 1 – 1000"
        android:inputType="numberDecimal"
        android:background="@drawable/bg_input_rounded"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textSize="14sp"
        android:textColor="#263238"
        android:textColorHint="#90A4AE"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Rebate Percentage"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#455A64"/>

        <TextView
            android:id="@+id/tvEditRebate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rebate: 0%"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#0097A7"/>

    </LinearLayout>

    <SeekBar
        android:id="@+id/sbEditRebate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="5"
        android:progressTint="#0097A7"
        android:thumbTint="#0097A7"
        android:layout_marginBottom="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="0%" android:textSize="11sp"
            android:textColor="#90A4AE"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="5%" android:textSize="11sp" android:textColor="#90A4AE"/>
    </LinearLayout>

</LinearLayout>